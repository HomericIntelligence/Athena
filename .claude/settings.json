{
  "enabledPlugins": {
    "athena@Athena": true
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(chmod -R 777 *)",
      "Bash(sudo *)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | sudo*)",
      "Bash(eval *)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.kube/**)",
      "Edit(~/.docker/**)",
      "Edit(~/.gnupg/**)",
      "Edit(.env)",
      "Edit(.env.*)"
    ]
  }
}
