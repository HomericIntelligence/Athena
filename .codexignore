# Codex marketplace-scanner ignore file.
# Mirrors .gitignore for paths that should not be parsed/skipped by Codex when
# scanning the Athena marketplace for plugin metadata.

# Generated plugin archive
dist/

# Python validation caches
__pycache__/

# Python virtual environments
.venv/
venv/
.pixi/

# Editor / OS
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# Secrets / credentials
.env
.env.*
*.pem
*.key
secrets/

# Git internals
.git/
.github/

# Athena internal iteration artefacts
scripts/_local/
tests/_local/
